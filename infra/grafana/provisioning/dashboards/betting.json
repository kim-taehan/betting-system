{
  "uid": "betting-ops",
  "title": "Betting — 운영 대시보드",
  "tags": ["betting"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "총 베팅 접수",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "expr": "ops_bets_placed_total", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 2, "type": "stat", "title": "정산 완료",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "expr": "sum(ops_bets_settled_total)", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 3, "type": "stat", "title": "리스크 알림",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "expr": "ops_risk_alerts_total", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 4, "type": "stat", "title": "지갑 변동",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "expr": "ops_wallet_changes_total", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "베팅 처리량 (건/분)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "expr": "rate(ops_bets_placed_total[1m]) * 60", "legendFormat": "베팅 접수/분", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "정산 결과 (누적 WON/LOST)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "expr": "ops_bets_settled_total", "legendFormat": "{{result}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "gRPC 서버 평균 지연 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "expr": "rate(grpc_server_seconds_sum[2m]) / clamp_min(rate(grpc_server_seconds_count[2m]), 0.0001) * 1000", "legendFormat": "{{rpc_service}}/{{rpc_method}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Risk 거절율 & Wallet 실패율",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(risk_checks_total{result=\"rejected\"}[5m])) / clamp_min(sum(rate(risk_checks_total[5m])), 0.0001)", "legendFormat": "Risk 거절율", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "sum(rate(wallet_debit_total{result=\"insufficient\"}[5m])) / clamp_min(sum(rate(wallet_debit_total[5m])), 0.0001)", "legendFormat": "Wallet 실패율", "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
